#! /bin/zsh

# Web video
if [[ $# < 1 ]]; then
  echo "Usage: videoconvert <original-videos>"
  echo "Usage: videoconvert big.mov"
  echo "Usage: videoconvert big.mov another-big.mov"
  echo "Usage: videoconvert *.mov"
  echo "Reampled will be created with the suffix '.web' before the extension."
  echo
  echo "With Env Vars."
  echo "Any can be changed."
  echo "Usage: FORMAT=mp4 SUFFIX=lowres WIDTH=1024 FASTER=no videoconvert *.mov"
else
  local format="${FORMAT:-mp4}"
  local suffix="${SUFFIX:-web}"
  local width="${WIDTH:-1280}"
  local faster="${FASTER:-no}"
  for f in $*; do
    #ffmpeg -i "$f" -filter:v "scale=${width}:-1" -c:a copy "${f:r}.${suffix}.${format}"
    # ffmpeg -i "$f" -vf "scale=${width}:-2" -c:v libx264 -movflags +faststart -c:a copy -an "${f:r}.${suffix}.${format}"
    # ffmpeg -i "$f" -movflags +faststart "${f:r}.${suffix}.${format}"
    if [[ "$faster" == "yes" ]]; then
      ffmpeg -i "$f" -filter:v "setpts=0.5*PTS" -movflags +faststart "${f:r}.${suffix}.${format}"
    else
      ffmpeg -i "$f" -movflags +faststart "${f:r}.${suffix}.${format}"
    fi
  done
fi

