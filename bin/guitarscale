#!/usr/bin/env nu

use std repeat

# Print guitar scales in the terminal for specific tunings.
# But it is naive and assumes the strings are all tuned with the same interval.
#
# Available scales:
#   major, minor, ionian, dorian, phrygian, lydian, mixolydian, aeolian, locrian,
#   penta, pentamajor, pentaminor, pentadorian, blues, double_harmonic
def main [
  --grid: string = "penta" # Essentially the scale
  --length: int = 3 # How many scales per line
  --strings: int = 4
  --offset: int = 7 # Essentially the tuning (7th fret means tuned in 5th)
] {

  let scales = {
    major:                  "1-2-34-5-6-7",
    minor:                  "@-@@-@-@@-@-",
    ionian:                 "@-@-@@-@-@-@",
    dorian:                 "@-@@-@-@-@@-",
    phrygian:               "@@-@-@-@@-@-",
    lydian:                 "@-@-@-@@-@-@",
    mixolydian:             "@-@-@@-@-@@-",
    aeolian:                "@-@@-@-@@-@-",
    locrian:                "@@-@-@@-@-@-",
    penta:                  "@--@-@-@--@-",
    pentamajor:             "@-@-@--@-@--",
    pentaminor:             "@--@-@-@--@-",
    pentadorian:            "@-@--@-@--@-",
    blues:                  "@--@-@@@--@-",
    double_harmonic:        "@@--@@-@@--@",
  }

  let grid = ($scales | get $grid)
  let grid_line = ($grid | repeat $length | str join)

  (($strings - 1)..0 | each {|n|
    let len = $grid_line | str length
    let char_offset = ($n * $offset) mod $len
    let rotated = if $char_offset == 0 {
      $grid_line
    } else {
      ($grid_line | str substring $char_offset..) + ($grid_line | str substring 0..($char_offset - 1))
    }
    let line = $rotated | split chars | str join ' '
    print $line
  })

  null
}

